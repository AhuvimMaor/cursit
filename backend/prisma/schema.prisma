datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum UserRole {
  BIS_CDR
  BRANCH_COORD
  TEAM_LEADER
  TRAINEE
}

enum CourseType {
  FOUNDATION
  ADVANCED
}

enum CourseInstanceStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum PhaseType {
  CANDIDACY_SUBMISSION
  TRYOUTS
  COMMANDER_COURSE
  STAFF_PREP
  COURSE
  SUMMARY_WEEK
  OTHER
}

enum CandidacyStatus {
  PENDING
  COORD_REVIEWED
  APPROVED
  REJECTED
}

enum RegistrationStatus {
  PENDING_COORD
  PENDING_BIS
  APPROVED
  REJECTED
}

// ──────────────────────────────────────────
// Organizational Structure
// ──────────────────────────────────────────

model Branch {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(128)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams Team[]
  users User[]
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(128)
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id        Int      @id @default(autoincrement())
  uniqueId  String   @unique @db.VarChar(64)
  name      String   @db.VarChar(128)
  role      UserRole
  teamId    Int?
  team      Team?    @relation(fields: [teamId], references: [id])
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidaciesAsCandidate CommandCandidacy[] @relation("CandidateUser")
  candidaciesAsSubmitter CommandCandidacy[] @relation("SubmitterUser")
  candidacyReviews       CommandCandidacy[] @relation("ReviewerUser")
  registrations          CourseRegistration[] @relation("RegistrantUser")
  coordApprovals         CourseRegistration[] @relation("CoordApprover")
  bisApprovals           CourseRegistration[] @relation("BisApprover")
}

// ──────────────────────────────────────────
// Course Catalog & Gantt
// ──────────────────────────────────────────

model Course {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(256)
  description  String     @db.Text
  type         CourseType
  requirements String?    @db.Text
  gmushHours   Int?
  location     String?    @db.VarChar(256)
  isPublished  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  instances    CourseInstance[]
  formTemplates FormTemplate[]
}

model CourseInstance {
  id        Int                  @id @default(autoincrement())
  courseId  Int
  course    Course               @relation(fields: [courseId], references: [id])
  name      String               @db.VarChar(128)
  startDate DateTime
  endDate   DateTime
  status    CourseInstanceStatus @default(DRAFT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  phases       CoursePhase[]
  candidacies  CommandCandidacy[]
  registrations CourseRegistration[]
}

model CoursePhase {
  id               Int           @id @default(autoincrement())
  courseInstanceId  Int
  courseInstance    CourseInstance @relation(fields: [courseInstanceId], references: [id], onDelete: Cascade)
  name             String        @db.VarChar(128)
  phaseType        PhaseType
  startDate        DateTime
  endDate          DateTime
  description      String?       @db.Text
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// ──────────────────────────────────────────
// Foundation: Command Candidacy
// ──────────────────────────────────────────

model CommandCandidacy {
  id               Int             @id @default(autoincrement())
  courseInstanceId  Int
  courseInstance    CourseInstance   @relation(fields: [courseInstanceId], references: [id])
  candidateId      Int
  candidate        User            @relation("CandidateUser", fields: [candidateId], references: [id])
  submittedById    Int
  submittedBy      User            @relation("SubmitterUser", fields: [submittedById], references: [id])
  status           CandidacyStatus @default(PENDING)
  motivation       String?         @db.Text
  commanderNotes   String?         @db.Text
  formData         Json?
  reviewedById     Int?
  reviewedBy       User?           @relation("ReviewerUser", fields: [reviewedById], references: [id])
  reviewNotes      String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([courseInstanceId, candidateId])
}

// ──────────────────────────────────────────
// Advanced: Course Registration
// ──────────────────────────────────────────

model CourseRegistration {
  id               Int                @id @default(autoincrement())
  courseInstanceId  Int
  courseInstance    CourseInstance      @relation(fields: [courseInstanceId], references: [id])
  userId           Int
  user             User               @relation("RegistrantUser", fields: [userId], references: [id])
  status           RegistrationStatus @default(PENDING_COORD)
  formData         Json?

  
  coordApprovedById Int?
  coordApprovedBy   User?     @relation("CoordApprover", fields: [coordApprovedById], references: [id])
  coordApprovedAt   DateTime?
  coordNotes        String?   @db.Text
  coordPriority     Int?      // תיעדוף ענפי

  
  bisApprovedById   Int?
  bisApprovedBy     User?     @relation("BisApprover", fields: [bisApprovedById], references: [id])
  bisApprovedAt     DateTime?
  bisNotes          String?   @db.Text

  // Rejection (any stage)
  rejectionReason   String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseInstanceId, userId])
}

// ──────────────────────────────────────────
// Forms & Info
// ──────────────────────────────────────────

model FormTemplate {
  id         Int      @id @default(autoincrement())
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id])
  name       String   @db.VarChar(128)
  fields     Json
  isRequired Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model InfoPage {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(128)
  title       String   @db.VarChar(256)
  content     String   @db.Text
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
