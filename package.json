{
  "name": "cursit",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "npm run format --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"node scripts/wait-for-port.mjs 8000 && npm run dev --workspace=frontend\"",
    "prisma:generate": "npm run prisma:generate --workspace=backend",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "prisma:studio": "npm run prisma:studio --workspace=backend",
    "docker:db": "docker compose up -d",
    "docker:local": "docker compose -f docker-compose.local.yml up --build",
    "docker:local:down": "docker compose -f docker-compose.local.yml down"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
